NODE_ENV=production
PORT=10000

# データベース設定（Render提供のPostgreSQL）
DATABASE_URL=${POSTGRES_URL}

# Supabase設定
SUPABASE_URL=${SUPABASE_URL}
SUPABASE_KEY=${SUPABASE_KEY}
SUPABASE_SERVICE_KEY=${SUPABASE_SERVICE_KEY}

# yt-dlp配置場所
YT_DLP_PATH=/opt/render/project/python/.pythonlibs/bin/yt-dlp

# デプロイ環境識別子
DEPLOY_ENV=render
