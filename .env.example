NODE_ENV=production
PORT=10000
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# デプロイ環境の指定（render、replitなど）
# Render環境ではDEPLOY_ENV=renderを設定
DEPLOY_ENV=

# yt-dlpのパスを明示的に指定（デプロイ環境によって異なる場合があります）
# YT_DLP_PATH=/path/to/yt-dlp

# 同期先インスタンスのURL（カンマ区切りで複数指定可能）
# 例: SYNC_INSTANCES=https://example1.com,https://example2.com
SYNC_INSTANCES=
